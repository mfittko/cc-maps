{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals", "@playwright/test"]
  },
  "include": [
    "tests/**/*.ts",
    "lib/**/*.ts",
    "pages/api/**/*.ts",
    "types/**/*.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "apps/ios", "build", "coverage", "test-results", "TestResults"]
}