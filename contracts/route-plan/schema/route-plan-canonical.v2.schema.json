{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-maps/contracts/route-plan/schema/route-plan-canonical.v2.schema.json",
  "title": "Route Plan Canonical v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "destinationId", "destinationIds", "anchorEdgeIds"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 2
    },
    "destinationId": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "destinationIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[0-9]+$"
      }
    },
    "anchorEdgeIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}